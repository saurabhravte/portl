{
  "name": "portl",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "doctor": "bunx expo-doctor",
    "config:public": "expo config --type public",
    "build:apk": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "build:staging": "eas build --platform all --profile staging",
    "build:production": "eas build --platform all --profile production",
    "update:preview": "eas update --channel preview --environment preview",
    "update:staging": "eas update --channel staging --environment production && npx sentry-expo-upload-sourcemaps dist",
    "update:prod": "eas update --channel production --environment production && npx sentry-expo-upload-sourcemaps dist",
    "test": "jest",
    "test:rls": "supabase test db",
    "test:edge": "bunx deno task --config supabase/functions/deno.json ci",
    "lint:db": "supabase db lint --local",
    "verify:demo-seed": "node ./scripts/verify-demo-seed.js",
    "gen:types": "node ./scripts/database-types.js --write",
    "check:types": "node ./scripts/database-types.js"
  },
  "dependencies": {
    "@clerk/expo": "^3.7.4",
    "@clerk/expo-google-signin": "^1.0.0",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.66.0",
    "date-fns": "^4.4.0",
    "expo": "~55.0.28",
    "expo-camera": "~55.0.21",
    "expo-constants": "~55.0.17",
    "expo-crypto": "~55.0.17",
    "expo-dev-client": "~55.0.37",
    "expo-device": "~55.0.19",
    "expo-document-picker": "~55.0.15",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.0",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.22",
    "expo-linking": "~55.0.16",
    "expo-local-authentication": "~55.0.16",
    "expo-notifications": "~55.0.0",
    "expo-print": "~55.0.17",
    "expo-router": "~55.0.17",
    "expo-secure-store": "~55.0.16",
    "expo-sharing": "~55.0.22",
    "expo-splash-screen": "~55.0.23",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.20",
    "expo-updates": "~55.0.14",
    "expo-web-browser": "~55.0.18",
    "iconoir-react-native": "^7.11.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-razorpay": "^3.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "^4.3.2",
    "uniwind": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@sentry/wizard": "^6.13.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.0",
    "supabase": "^2.109.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay",
          "@solana-mobile/mobile-wallet-adapter-protocol"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
