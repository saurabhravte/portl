# Copy to .env.local for development. Never commit populated env files.
# EXPO_PUBLIC_* values are bundled into the app and are not secrets.
APP_ENV=development
EXPO_APP_NAME=Portl
APP_VERSION=1.0.0
IOS_BUILD_NUMBER=1
ANDROID_VERSION_CODE=1

# Expo account/project and stable store identifiers.
EXPO_OWNER=
EAS_PROJECT_ID=
EXPO_IOS_BUNDLE_IDENTIFIER=com.example.portl
EXPO_ANDROID_PACKAGE=com.example.portl

# Public mobile runtime configuration.
EXPO_PUBLIC_SUPABASE_URL=https://example.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# ImageKit.io media backend. When both are set, photo uploads (visitor,
# complaint, notice, poll) go to ImageKit instead of Supabase Storage.
# The public key and URL endpoint are safe to bundle; the PRIVATE key is
# server-side only (set on the imagekit-auth Edge Function, below).
EXPO_PUBLIC_IMAGEKIT_PUBLIC_KEY=
EXPO_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Google Sign-In (Clerk + Google Cloud OAuth). Required for Continue with Google.
# Create Web + iOS + Android OAuth clients, then paste IDs here / in EAS env.
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=
# Optional iOS native picker (part of iOS client id before .apps.googleusercontent.com):
# EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.YOUR_IOS_CLIENT_ID


# Sentry build-time source-map configuration.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Supabase Edge Function / database webhook configuration. Server-side only.
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically in
# deployed Edge Functions; set them only when serving the function locally.
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SEND_PUSH_WEBHOOK_URL=https://example.supabase.co/functions/v1/send-push
SEND_PUSH_WEBHOOK_SECRET=
CLERK_SECRET_KEY=
PRIVACY_WORKER_SECRET=
ACCOUNT_DELETION_GRACE_DAYS=
PRIVACY_ARTIFACT_TTL_HOURS=
SIGNED_URL_TTL_SECONDS=

# Razorpay (client key is public; secret is server-side only, set on Edge Functions).
EXPO_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ImageKit private key — server-side only. Set on the imagekit-auth Edge
# Function: supabase secrets set IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_PRIVATE_KEY=
